# SSH config generated by Terraform (local_file.ssh_config) on apply.
# Do not edit by hand; changes are overwritten. Usage: ssh -F ansible/ssh_config <name>
%{ for name, ip in servers ~}
Host ${name}
    HostName ${ip}
    User build
    Port ${ssh_port}
    IdentityFile ${identity_file}
    # Keep idle connections alive so a NAT/firewall doesn't reap the flow
    # (the cause of "client_loop: send disconnect: Broken pipe").
    ServerAliveInterval 60
    ServerAliveCountMax 3
%{ endfor ~}
